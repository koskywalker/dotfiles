{
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude Code' -subtitle \"${CLAUDE_PROJECT_DIR##*/}\" -message '許可を求めています' -sound Glass"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude Code' -subtitle \"${CLAUDE_PROJECT_DIR##*/}\" -message '入力待ちです' -sound Hero"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title 'Claude Code' -subtitle \"${CLAUDE_PROJECT_DIR##*/}\" -message '処理が完了しました' -sound Default"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "warp@claude-code-warp": false
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    },
    "turso": {
      "source": {
        "source": "github",
        "repo": "tursodatabase/turso-mcp"
      }
    }
  },
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "stable",
  "tui": "default",
  "skipWorkflowUsageWarning": true,
  "preferredNotifChannel": "notifications_disabled",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
